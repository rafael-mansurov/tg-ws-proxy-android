<?xml version="1.0" encoding="utf-8"?>
<paths xmlns:android="http://schemas.android.com/apk/res/android">
    <!-- Unpacked Python app lives under Context.getFilesDir()/app/ (PythonActivity.getAppRoot). -->
    <files-path name="tgws_app" path="app" />
    <!-- Копия обложки перед шарингом: часть мессенджеров (Telegram) стабильнее принимает content:// из cache. -->
    <cache-path name="tgws_share" path="share" />
</paths>
